# ============================================================================
# CENAYANG MARKET - Environment Configuration for Live Trading
# ============================================================================

# Environment
NODE_ENV=production
RUST_LOG=info
GIN_MODE=release

# Exchange Configuration
EXCHANGE_WS_URL=wss://stream.binance.com:9443/ws
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# API Configuration
API_PORT=8090
RUST_PORT=8080
FRONTEND_PORT=3000

# Risk Management
MAX_DRAWDOWN_PCT=5.0
MAX_POSITION_SIZE=100000
DAILY_LOSS_LIMIT=10000
KILL_SWITCH_ENABLED=true

# Message Broker
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379

# Database (optional for persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/cenayang

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin123

# Performance Tuning
RING_BUFFER_SIZE=65536
HISTOGRAM_BUCKETS=4096
NUM_SHARDS=64
BATCH_SIZE=1024

# Frontend
VITE_API_URL=http://localhost:8090
VITE_WS_URL=ws://localhost:8090/ws
